@page "/post/{Slug}"
@using ZikiBlog.Data
@using ZikiBlog.Models
@inject IPostRepository PostsRepo
@inject IJSRuntime JS
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<div class="container py-5">
    @if (post is null)
    {
        <div class="alert alert-warning">Innlegg ikke funnet.</div>
    }
    else
    {
        <article class="post-article mx-auto" style="max-width: 900px;">
            <h1 class="post-title display-5">@post.Title</h1>
            <div class="post-meta">
                <span class="post-meta-item">Publisert @post.PublishedAt?.ToString("dd. MMMM yyyy")</span>
            </div>
            <div class="content">
                @((MarkupString)post.ContentHtml)
            </div>
        </article>
    }
</div>

<!-- Image Modal -->
<div class="modal fade" id="imageModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content bg-transparent border-0">
            <div class="modal-body p-0 position-relative">
                <button type="button" class="btn-close btn-close-white position-absolute top-0 end-0 m-3" data-bs-dismiss="modal" aria-label="Close" style="z-index: 1050;"></button>
                <img id="modalImage" src="" class="img-fluid w-100" alt="" />
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string Slug { get; set; } = string.Empty;
    private Post? post;

    protected override async Task OnParametersSetAsync()
    {
        post = await PostsRepo.GetBySlugAsync(Slug);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (post != null)
        {
            await JS.InvokeVoidAsync("initImageModal");
        }
    }
}
