@page "/post/{Slug}"
@using ZikiBlog.Data
@using ZikiBlog.Models
@inject IPostRepository PostsRepo

<div class="container py-4">
    @if (post is null)
    {
        <div class="alert alert-warning">Innlegg ikke funnet.</div>
    }
    else
    {
        <article class="mx-auto" style="max-width: 900px;">
            <h1 class="display-5">@post.Title</h1>
            <p class="text-muted">Publisert @post.PublishedAt?.ToString("yyyy-MM-dd")</p>
            <hr />
            <div class="mt-3 content" @onclick:stopPropagation>
                @((MarkupString)post.ContentHtml)
            </div>
        </article>
    }
</div>

@code {
    [Parameter] public string Slug { get; set; } = string.Empty;
    private Post? post;

    protected override async Task OnParametersSetAsync()
    {
        post = await PostsRepo.GetBySlugAsync(Slug);
    }
}
