@page "/"
@using ZikiBlog.Data
@using ZikiBlog.Models
@inject IPostRepository PostsRepo
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<div class="container py-5">
    <h1 class="section-title display-6">Blogg</h1>
    @if (items is null)
    {
        <div class="loading-placeholder">Laster…</div>
    }
    else if (!items.Any())
    {
        <div class="alert alert-info mt-3">Ingen innlegg ennå.</div>
    }
    else
    {
        <div class="row row-cols-1 g-4 mt-1">
            @foreach (var p in items)
            {
                <div class="col">
                    <div class="post-card">
                        <div class="card-body p-4">
                            <h2 class="post-card-title h4">
                                <a href=@($"/post/{p.Slug}")>@p.Title</a>
                            </h2>
                            <div class="post-date">@p.PublishedAt?.ToString("yyyy-MM-dd")</div>
                            @if (!string.IsNullOrWhiteSpace(p.Summary))
                            {
                                <p class="post-summary">@p.Summary</p>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private IEnumerable<Post>? items;

    protected override async Task OnInitializedAsync()
    {
        var (list, total) = await PostsRepo.GetPagedAsync(1, 10, onlyPublished: true);
        items = list;
    }
}
