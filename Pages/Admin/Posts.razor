@page "/admin/posts"
@attribute [Authorize(Roles = "Admin")]
@using ZikiBlog.Models
@using ZikiBlog.Data
@inject IPostRepository PostsRepo
@inject ZikiBlog.Services.SlugService Slugs

<div class="container py-4">
    <h1 class="h3 mb-3">Administrer innlegg</h1>

    <div class="card mb-4">
        <div class="card-body">
            <EditForm Model="editModel" OnValidSubmit="OnSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="row g-3">
                    <div class="col-md-8">
                        <input class="form-control" placeholder="Tittel" @bind="editModel.Title" />
                    </div>
                    <div class="col-md-4">
                        <div class="input-group">
                            <input class="form-control" placeholder="Slug" @bind="editModel.Slug" />
                            <button type="button" class="btn btn-outline-secondary" @onclick="GenerateSlug">Generer</button>
                        </div>
                    </div>
                    <div class="col-12">
                        <textarea class="form-control" placeholder="HTML-innhold" rows="10" @bind="editModel.ContentHtml"></textarea>
                    </div>
                    <div class="col-md-8">
                        <input class="form-control" placeholder="Sammendrag (valgfritt)" @bind="editModel.Summary" />
                    </div>
                    <div class="col-md-4 d-flex align-items-center">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="published" @bind="editModel.IsPublished" />
                            <label for="published" class="form-check-label">Publisert</label>
                        </div>
                    </div>
                    <div class="col-12 d-flex gap-2">
                        <button type="submit" class="btn btn-primary">@((editModel.Id == Guid.Empty) ? "Opprett" : "Oppdater")</button>
                        @if (editModel.Id != Guid.Empty)
                        {
                            <button class="btn btn-danger" type="button" @onclick="Delete">Slett</button>
                            <button class="btn btn-secondary" type="button" @onclick="CancelEdit">Avbryt</button>
                        }
                    </div>
                </div>
            </EditForm>
        </div>
    </div>

    @if (items is null)
    {
        <div class="text-secondary">Laster…</div>
    }
    else
    {
        <div class="card">
            <div class="table-responsive">
                <table class="table table-striped mb-0">
                    <thead class="table-light"><tr><th>Tittel</th><th>Slug</th><th>Publisert</th><th style="width:1%"></th></tr></thead>
                    <tbody>
                        @foreach (var p in items)
                        {
                            <tr>
                                <td>@p.Title</td>
                                <td>@p.Slug</td>
                                <td>@p.PublishedAt?.ToString("yyyy-MM-dd")</td>
                                <td class="text-nowrap"><button class="btn btn-sm btn-outline-primary" @onclick="() => StartEdit(p)">Rediger</button></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private List<Post>? items;
    private Post editModel = new();

    protected override async Task OnInitializedAsync()
    {
        await Reload();
    }

    private async Task Reload()
    {
        var (list, total) = await PostsRepo.GetPagedAsync(1, 100, onlyPublished: false);
        items = list.ToList();
    }

    private void StartEdit(Post p)
    {
        editModel = new Post
        {
            Id = p.Id,
            Title = p.Title,
            Slug = p.Slug,
            ContentHtml = p.ContentHtml,
            Summary = p.Summary,
            PublishedAt = p.PublishedAt,
            IsPublished = p.IsPublished
        };
    }

    private async Task OnSubmit()
    {
        if (editModel.Id == Guid.Empty)
        {
            if (string.IsNullOrWhiteSpace(editModel.Slug)) editModel.Slug = Slugs.Generate(editModel.Title);
            await PostsRepo.CreateAsync(editModel);
        }
        else
        {
            if (string.IsNullOrWhiteSpace(editModel.Slug)) editModel.Slug = Slugs.Generate(editModel.Title);
            await PostsRepo.UpdateAsync(editModel);
        }
        editModel = new();
        await Reload();
    }

    private void GenerateSlug() => editModel.Slug = Slugs.Generate(editModel.Title);

    private async Task Delete()
    {
        await PostsRepo.DeleteAsync(editModel.Id);
        editModel = new();
        await Reload();
    }

    private void CancelEdit() => editModel = new();
}
